{
    "name": "stefanov1989/ariel-radix-router",
    "description": "A fast, dependency-free radix-tree HTTP router for PHP 8.4 with middleware, route groups and compiled caches.",
    "type": "library",
    "license": "MIT",
    "keywords": ["router", "routing", "radix", "middleware", "http", "ariel"],
    "require": {
        "php": ">=8.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "StefanoV1989\\ArielRouter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StefanoV1989\\ArielRouter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=1G",
        "check": ["@test", "@stan"]
    },
    "support": {
        "issues": "https://github.com/StefanoV1989/ariel-radix-router/issues",
        "source": "https://github.com/StefanoV1989/ariel-radix-router"
    },
    "authors": [
        {
            "name": "Stefano Venneri",
            "email": "anonymouz89@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
